              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Depression Screening\", \"title_ar\": \"فحص الاكتئاب\", \"category\": \"mental_health\", \"scoring_type\": \"sum\", \"questions\": [{\"question_text\": \"Little interest in doing things\", \"question_text_ar\": \"قلة الاهتمام بالأشياء\", \"options\": [{\"option_text\": \"Not at all\", \"option_text_ar\": \"أبداً\", \"option_value\": 0, \"emoji\": \"😊\"}, {\"option_text\": \"Several days\", \"option_text_ar\": \"عدة أيام\", \"option_value\": 1, \"emoji\": \"😐\"}, {\"option_text\": \"More than half\", \"option_text_ar\": \"أكثر من النصف\", \"option_value\": 2, \"emoji\": \"😔\"}, {\"option_text\": \"Nearly every day\", \"option_text_ar\": \"تقريباً كل يوم\", \"option_value\": 3, \"emoji\": \"😢\"}]}, {\"question_text\": \"Feeling down or hopeless\", \"question_text_ar\": \"الشعور بالحزن أو اليأس\", \"options\": [{\"option_text\": \"Not at all\", \"option_text_ar\": \"أبداً\", \"option_value\": 0, \"emoji\": \"😊\"}, {\"option_text\": \"Several days\", \"option_text_ar\": \"عدة أيام\", \"option_value\": 1, \"emoji\": \"😐\"}, {\"option_text\": \"More than half\", \"option_text_ar\": \"أكثر من النصف\", \"option_value\": 2, \"emoji\": \"😔\"}, {\"option_text\": \"Nearly every day\", \"option_text_ar\": \"تقريباً كل يوم\", \"option_value\": 3, \"emoji\": \"😢\"}]}]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r=pm.response.json();if(r.success)pm.collectionVariables.set(\"assessment_id\",String(r.data.id))"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Assessment Details",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/assessments/{{assessment_id}}",
            "header": [
